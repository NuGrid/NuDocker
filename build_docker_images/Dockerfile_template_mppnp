# This is the MPPNP Dockerfile template for building NuDocker images with additional packages
# Based on the default template but includes HDF5, OpenMPI, and NuSE
#
# This template supports two toolchain variants, selected with the VARIANT build-arg:
#
#   master   (default) - original pinned toolchain: gcc 7.3.0 / hdf5 1.8.20 / openmpi 3.0.1
#       docker build -t mppnp:master .
#
#   modular2 - gcc 12.4.0 / hdf5 1.8.3 / openmpi 4.1.6
#       docker build --build-arg VARIANT=modular2 -t mppnp:modular2 .
#
# Both variants run through the same shared setup (apt packages, user creation) and the
# same shared finishing steps (Python packages, NuGridPy, mesasdk), only the compiled
# toolchain versions differ.

ARG UBUNTU_VERSION=mm.nn
ARG VARIANT=master

# ---------------------------------------------------------------------------
# base: OS-level setup shared by every variant
# ---------------------------------------------------------------------------
FROM ubuntu:${UBUNTU_VERSION} AS base

LABEL maintainer="Falk Herwig <fherwig@uvic.ca>"

COPY apt_packages_nudome.txt /tmp/apt_packages_nudome.txt

RUN apt-get update && \
    apt-get -y install $(cat /tmp/apt_packages_nudome.txt) && \
    apt-get autoremove --yes && apt-get clean all && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

RUN useradd -d /home/user -m -c "" user && \
    chown -R user:user /home/user && \
    chmod -R 775 /home/user/

# ---------------------------------------------------------------------------
# master: gcc 7.3.0 / hdf5 1.8.20 / openmpi 3.0.1 / OpenBLAS / NuSE
# ---------------------------------------------------------------------------
FROM base AS master

ARG GCC_VERSION=7.3.0
ARG HDF5_VERSION=1.8.20
ARG HDF5_URL_PATH=prev-releases
ARG OPENMPI_VERSION=3.0.1
ARG OPENMPI_SERIES=3.0

# Install GCC
RUN (cd /tmp ; \
    wget https://ftp.gnu.org/gnu/gcc/gcc-${GCC_VERSION}/gcc-${GCC_VERSION}.tar.gz ; \
    tar -xzvf gcc-${GCC_VERSION}.tar.gz; cd gcc-${GCC_VERSION} ; \
    ./contrib/download_prerequisites ; \
    mkdir build; cd build ; \
    ../configure --prefix=/opt/gcc-${GCC_VERSION} --enable-languages=c,c++,fortran --disable-multilib ; \
    make -j$(nproc) ; make install; cd ../..; rm -rf gcc*)

RUN echo Installed gcc ${GCC_VERSION} ..........

# Toolchain environment for the master variant. Set here (not in .bash_aliases)
# so every process in the container gets the right compiler/MPI/libs, and so the
# value tracks the version ARGs above. Placed BEFORE the hdf5/openmpi builds so
# their ./configure Fortran tests can find libgfortran from /opt/gcc (referencing
# the not-yet-built /opt/openmpi lib dir here is harmless). Inherited by the
# shared `toolchain` stage. (master's gcc-7.3.0 libgfortran.so.4 happens to match
# the system apt gfortran-7, so master built even before this was moved up, but
# keeping it early is correct and mirrors modular2.)
ENV PATH=/opt/gcc-${GCC_VERSION}/bin:/opt/openmpi-${OPENMPI_VERSION}/bin:$PATH
ENV LD_LIBRARY_PATH=/opt/gcc-${GCC_VERSION}/lib64:/opt/openblas-0.2.20/lib:/opt/hdf5-${HDF5_VERSION}/lib:/opt/openmpi-${OPENMPI_VERSION}/lib

# Install OpenBLAS 0.2.20
RUN (cd /tmp ; \
    wget https://github.com/OpenMathLib/OpenBLAS/releases/download/v0.2.20/OpenBLAS-0.2.20.tar.gz ; \
    tar -xzvf OpenBLAS-0.2.20.tar.gz; cd OpenBLAS-0.2.20 ; \
    make CC=/opt/gcc-${GCC_VERSION}/bin/gcc FC=/opt/gcc-${GCC_VERSION}/bin/gfortran ; \
    make PREFIX=/opt/openblas-0.2.20 install; cd ..; rm -rf OpenBLAS*)

RUN echo Installed openblas 0.2.20 ..........

# Install HDF5
RUN (cd /tmp ; \
    wget https://support.hdfgroup.org/ftp/HDF5/${HDF5_URL_PATH}/hdf5-1.8/hdf5-${HDF5_VERSION}/src/hdf5-${HDF5_VERSION}.tar.gz ; \
    tar -xzvf hdf5-${HDF5_VERSION}.tar.gz; cd hdf5-${HDF5_VERSION} ; \
    ./configure --prefix=/opt/hdf5-${HDF5_VERSION} --enable-fortran --enable-shared CC=/opt/gcc-${GCC_VERSION}/bin/gcc FC=/opt/gcc-${GCC_VERSION}/bin/gfortran F77=/opt/gcc-${GCC_VERSION}/bin/gfortran ; \
    make ; make install; cd ..; rm -rf hdf5*)

RUN echo Installed hdf5 ${HDF5_VERSION} ..........

# Install OpenMPI
RUN (cd /tmp ; \
    wget https://download.open-mpi.org/release/open-mpi/v${OPENMPI_SERIES}/openmpi-${OPENMPI_VERSION}.tar.gz; \
    tar -xzvf openmpi-${OPENMPI_VERSION}.tar.gz ; cd openmpi-${OPENMPI_VERSION}; \
    ./configure --prefix=/opt/openmpi-${OPENMPI_VERSION} CC=/opt/gcc-${GCC_VERSION}/bin/gcc CXX=/opt/gcc-${GCC_VERSION}/bin/g++ FC=/opt/gcc-${GCC_VERSION}/bin/gfortran ; \
    make all install; cd ..; rm -rf openmpi*)

RUN echo Installed openmpi ${OPENMPI_VERSION} ..........

# Install NuSE
RUN ([ ! -d /opt/se-1.2 ] && (cd /tmp; \
    git clone https://github.com/NuGrid/NuSE.git ;\
    cd NuSE/SE; \
    ./configure --prefix=/opt/se-1.2 --with-hdf5=/opt/hdf5-${HDF5_VERSION};\
    make; make install; cd ../..; rm -rf NuSE))

RUN echo Installed nuse ..........

# (master toolchain ENV is set above, right after the gcc install.)

# ----------------------------------------------------------------------------------------------
# modular2: gcc 12.4.0 / hdf5 1.8.3 / openmpi 4.1.6 / No need to self-install OpenBLAS and NuSE
# ----------------------------------------------------------------------------------------------
FROM base AS modular2

ARG GCC_VERSION=12.4.0
ARG HDF5_VERSION=1.8.3
ARG HDF5_URL_PATH=releases
ARG OPENMPI_VERSION=4.1.6
ARG OPENMPI_SERIES=4.1

# Install GCC
RUN (cd /tmp ; \
    wget https://ftp.gnu.org/gnu/gcc/gcc-${GCC_VERSION}/gcc-${GCC_VERSION}.tar.gz ; \
    tar -xzvf gcc-${GCC_VERSION}.tar.gz; cd gcc-${GCC_VERSION} ; \
    ./contrib/download_prerequisites ; \
    mkdir build; cd build ; \
    ../configure --prefix=/opt/gcc-${GCC_VERSION} --enable-languages=c,c++,fortran --disable-multilib ; \
    make -j$(nproc) ; make install; cd ../..; rm -rf gcc*)

RUN echo Installed gcc ${GCC_VERSION} ..........

# Toolchain environment for the modular2 variant. Set BEFORE the hdf5/openmpi
# builds: their ./configure runs a Fortran test executable that links
# libgfortran.so.5 from the freshly built gcc-12.4.0, which is NOT on the
# system linker path, so without this LD_LIBRARY_PATH the OpenMPI configure
# fails ("Could not run a simple Fortran program") and — because the RUN chain
# ends in `rm -rf` — silently leaves the image with no /opt/openmpi. Referencing
# the not-yet-built /opt/openmpi lib dir here is harmless. modular2 links system
# BLAS (apt libopenblas-dev) and builds its own hdf5/NuSE/SuperLU into the nuppn
# tree at compile time, so only compiler + MPI need to be on PATH here.
# (CMake is added at the END of this stage so it doesn't invalidate the hdf5/
# openmpi build cache — it's only needed at nuppn-compile time, not image build.)
ENV PATH=/opt/gcc-${GCC_VERSION}/bin:/opt/openmpi-${OPENMPI_VERSION}/bin:$PATH
ENV LD_LIBRARY_PATH=/opt/gcc-${GCC_VERSION}/lib64:/opt/hdf5-${HDF5_VERSION}/lib:/opt/openmpi-${OPENMPI_VERSION}/lib

# Install HDF5
RUN (cd /tmp ; \
    wget https://support.hdfgroup.org/ftp/HDF5/${HDF5_URL_PATH}/hdf5-1.8/hdf5-${HDF5_VERSION}/src/hdf5-${HDF5_VERSION}.tar.gz ; \
    tar -xzvf hdf5-${HDF5_VERSION}.tar.gz; cd hdf5-${HDF5_VERSION} ; \
    ./configure --prefix=/opt/hdf5-${HDF5_VERSION} --enable-fortran --enable-shared CC=/opt/gcc-${GCC_VERSION}/bin/gcc FC=/opt/gcc-${GCC_VERSION}/bin/gfortran F77=/opt/gcc-${GCC_VERSION}/bin/gfortran ; \
    make ; make install; cd ..; rm -rf hdf5*)

RUN echo Installed hdf5 ${HDF5_VERSION} ..........

# Install OpenMPI
RUN (cd /tmp ; \
    wget https://download.open-mpi.org/release/open-mpi/v${OPENMPI_SERIES}/openmpi-${OPENMPI_VERSION}.tar.gz; \
    tar -xzvf openmpi-${OPENMPI_VERSION}.tar.gz ; cd openmpi-${OPENMPI_VERSION}; \
    ./configure --prefix=/opt/openmpi-${OPENMPI_VERSION} CC=/opt/gcc-${GCC_VERSION}/bin/gcc CXX=/opt/gcc-${GCC_VERSION}/bin/g++ FC=/opt/gcc-${GCC_VERSION}/bin/gfortran \
      && make all install; cd ..; rm -rf openmpi*)
RUN test -x /opt/openmpi-${OPENMPI_VERSION}/bin/mpif90   # fail loudly if the openmpi build above was skipped

RUN echo Installed openmpi ${OPENMPI_VERSION} ..........

# Install a modern CMake (apt's 3.10.2 on Ubuntu 18.04 is too old — modular2's
# SuperLU CMakeLists requires >= 3.12). Official Kitware binary release, no
# compile. Placed LAST in the stage (after the cacheable hdf5/openmpi builds)
# and prepended to PATH so SuperLU's build sees 3.28, not apt's 3.10.2. The ARG
# lives here (not up top) so it does not invalidate the gcc/hdf5/openmpi cache.
ARG CMAKE_VERSION=3.28.3
RUN (cd /tmp ; \
    wget https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}-linux-x86_64.tar.gz ; \
    tar -xzf cmake-${CMAKE_VERSION}-linux-x86_64.tar.gz -C /opt ; \
    mv /opt/cmake-${CMAKE_VERSION}-linux-x86_64 /opt/cmake ; \
    rm -f cmake-${CMAKE_VERSION}-linux-x86_64.tar.gz)
RUN test -x /opt/cmake/bin/cmake   # fail loudly if the cmake install above was skipped
ENV PATH=/opt/cmake/bin:$PATH

# Build OpenBLAS from source with gcc-12.4.0 so the mppnp binary links a BLAS
# whose Fortran runtime (libgfortran.so.5) MATCHES our gcc-12 code. The apt
# libopenblas is built with 18.04's gfortran-7 (libgfortran.so.4), which would
# otherwise get pulled in transitively and load a SECOND libgfortran alongside
# ours -- a latent runtime hazard. DYNAMIC_ARCH=1 makes the kernels portable
# across x86-64 host CPUs (important for a distributed image). The libblas/
# liblapack symlinks let nuppn's hardcoded `-lblas` resolve here (nuppn's
# nudome_mppnp Make.local adds -L/opt/openblas-*/lib so ours wins over apt's).
# Placed after the cacheable hdf5/openmpi/cmake steps; the ENV that puts it on
# LD_LIBRARY_PATH is appended so it doesn't invalidate those layers.
ARG OPENBLAS_VERSION=0.3.27
RUN (cd /tmp ; \
    wget https://github.com/OpenMathLib/OpenBLAS/releases/download/v${OPENBLAS_VERSION}/OpenBLAS-${OPENBLAS_VERSION}.tar.gz ; \
    tar -xzf OpenBLAS-${OPENBLAS_VERSION}.tar.gz ; cd OpenBLAS-${OPENBLAS_VERSION} ; \
    make -j$(nproc) DYNAMIC_ARCH=1 CC=/opt/gcc-${GCC_VERSION}/bin/gcc FC=/opt/gcc-${GCC_VERSION}/bin/gfortran \
      && make PREFIX=/opt/openblas-${OPENBLAS_VERSION} install ; \
    cd .. ; rm -rf OpenBLAS-${OPENBLAS_VERSION}*)
RUN cd /opt/openblas-${OPENBLAS_VERSION}/lib \
    && ln -sf libopenblas.so libblas.so   && ln -sf libopenblas.so libblas.so.3 \
    && ln -sf libopenblas.so liblapack.so && ln -sf libopenblas.so liblapack.so.3
RUN test -e /opt/openblas-${OPENBLAS_VERSION}/lib/libblas.so   # fail loudly if the openblas build/symlink above was skipped
ENV LD_LIBRARY_PATH=/opt/openblas-${OPENBLAS_VERSION}/lib:$LD_LIBRARY_PATH

# ---------------------------------------------------------------------------
# toolchain: picks master or modular2 as the base, via the VARIANT build-arg
# ---------------------------------------------------------------------------
FROM ${VARIANT} AS toolchain

# Install Python packages
COPY requirements_nudome.txt /tmp/requirements_nudome.txt
RUN python3 -m pip install --upgrade pip setuptools wheel && \
    python3 -m pip install -r /tmp/requirements_nudome.txt

RUN echo Installed Python packages

# Install NuGridPy on your own
COPY NuGridPy /opt/NuGridPy
RUN python3 -m pip install -e /opt/NuGridPy

RUN echo Installed NuGridPy

COPY dot.bash_aliases /home/user/.bash_aliases
RUN chown user:user /home/user/.bash_aliases

USER user

USER user
ENV HOME=/home/user
WORKDIR /home/user
